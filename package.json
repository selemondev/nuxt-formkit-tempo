{
  "name": "nuxt-formkit-tempo",
  "version": "1.3.3",
  "description": "The easiest way to work with dates in Nuxt 3. The unofficial Nuxt module port of @formkit/tempo 🕑.",
  "repository": "https://github.com/selemondev/nuxt-formkit-tempo",
  "author": {
    "name": "Selemon Brahanu"
  },
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/types.d.mts",
      "import": "./dist/module.mjs"
    }
  },
  "main": "./dist/module.mjs",
  "files": [
    "dist"
  ],
  "keywords": [
    "nuxt3",
    "nuxt4",
    "dates",
    "javascript-dates",
    "time",
    "nuxt-module"
  ],
  "scripts": {
    "prepack": "pnpx esno@latest script/generate-runtime-import && nuxt-module-build build",
    "dev": "nuxi dev playground",
    "dev:build": "nuxi build playground",
    "dev:prepare": "nuxt-module-build build --stub && nuxt-module-build prepare && nuxi prepare playground",
    "release": "pnpm lint && pnpm prepack && pnpm dlx changelogen --release --hideAuthorEmail && git push --follow-tags",
    "lint": "eslint . --fix",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:types": "vue-tsc --noEmit && cd playground && vue-tsc --noEmit"
  },
  "dependencies": {
    "@formkit/tempo": "^0.1.2"
  },
  "devDependencies": {
    "@nuxt/devtools": "^2.7.0",
    "@nuxt/eslint-config": "^1.15.2",
    "@nuxt/kit": "^4.3.1",
    "@nuxt/module-builder": "^1.0.2",
    "@nuxt/schema": "^4.3.1",
    "@nuxt/test-utils": "^3.23.0",
    "@types/node": "latest",
    "eslint": "^9.39.3",
    "nuxt": "^4.3.1",
    "typescript": "~5.9.3",
    "vitest": "^3.2.4",
    "vue-tsc": "^3.2.5"
  },
  "pnpm": {
    "overrides": {
      "citty": "0.2.1"
    }
  },
  "packageManager": "pnpm@10.30.3"
}
